    "#normalization\n",
    "import numpy as np\n",
    "\n",
    "arr1 = np.array([[1,2],[3,4]])\n",
    "mean = np.mean(arr1)\n",
    "\n",
    "std_dvn= np.std(arr1)\n",
    "\n",
    "normal_arr = (arr1-mean)/std_dvn\n",
    "print(normal_arr)\n",
    "\n",
    "print (mean)\n",
    "print(std_dvn)"
   ]
